{
	"name": "fn-starwars-peoples",
	"version": "0.1.0",
	"description": "",
	"autor":"SebastianEPH",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"start:api": "cross-env NODE_ENV=LOCAL serverless offline",
		"deploy": "npm run sls-build && cross-env NODE_ENV=PROD serverless deploy --aws-profile default --force",
		"zip": "./zip.sh",
		"build": "tsc",
		"package": "npm run sls-build && mkdir dist && mv ./.serverless/${npm_package_name}.zip ./dist/src.zip",
		"lint": "eslint {src,test}/**",
		"lint:fix": "eslint --fix {src,test}/**",
		"format": "prettier --check {src,test}/**",
		"format:fix": "prettier --write {src,test}/**",
		"test": "jest",
		"test:watch": "jest --watchAll",
		"test:coverage": "jest --coverage",
		"prepare": "rm -rf .husky &&  husky install",
		"prepare-win": "rmdir /s /q .husky && husky install",
		"sls-build": "sls package"
	},
	"dependencies": {
		"@aws-sdk/client-lambda": "^3.454.0",
		"@types/mysql": "^2.15.24",
		"axios": "^1.6.2",
		"class-validator": "^0.14.0",
		"dotenv": "^16.3.1",
		"inversify": "^6.0.2",
		"mysql2": "^3.6.5",
		"reflect-metadata": "^0.1.13",
		"ts-log-debug": "^5.5.3"
	},
	"devDependencies": {
		"@commitlint/cli": "^17.6.3",
		"@commitlint/config-conventional": "^17.6.3",
		"@types/aws-lambda": "^8.10.92",
		"@types/debug": "^4.1.7",
		"@types/dotenv-safe": "^8.1.2",
		"@types/jest": "^29.5.0",
		"@types/node": "^18.15.11",
		"@types/supertest": "^2.0.12",
		"@typescript-eslint/eslint-plugin": "^5.58.0",
		"@typescript-eslint/parser": "^5.58.0",
		"axios-mock-adapter": "^1.21.4",
		"cross-env": "^7.0.3",
		"eslint": "^8.38.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-airbnb-typescript": "^17.0.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-import": "^2.27.5",
		"eslint-plugin-n": "^15.7.0",
		"eslint-plugin-promise": "^6.1.1",
		"husky": "^8.0.3",
		"jest": "^29.5.0",
		"prettier": "^2.8.7",
		"serverless": "^3.36.0",
		"serverless-bundle-no-pg-native": "^1.3.0",
		"serverless-esbuild": "^1.43.0",
		"serverless-offline": "^12.0.4",
		"ts-jest": "^29.1.0",
		"ts-node": "^10.9.1",
		"tsc-watch": "^6.0.0",
		"typescript": "^5.0.4"
	},
	"keywords": [
		"Nodejs",
		"TypeScript"
	]
}
